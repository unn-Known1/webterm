{
  "name": "webtun",
  "version": "1.0.0",
  "description": "Self-hosted web terminal with Cloudflare Tunnel, file explorer, and PWA support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "node -e \"try{require('child_process').execSync('command -v cloudflared >/dev/null 2>&1 || curl -sL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-'+({x64:'amd64',arm64:'arm64'})[process.arch]+' -o /usr/local/bin/cloudflared && chmod +x /usr/local/bin/cloudflared',{stdio:'inherit'})}catch(e){process.exit(0)}\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "node-pty": "^1.0.0",
    "multer": "^2.0.0",
    "dotenv": "^16.4.1",
    "mime-types": "^2.1.35",
    "archiver": "^6.0.1"
  }
}
